<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quora Posts</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
   <h2>Quora Posts</h2>

   <div class="posts-container">
       <% for(post of posts) { %>
        <div class="post">
            <h3 class="username">@<%= post.username %></h3> 
            <h4 class="content"><%= post.content %></h4>
            <br/>
            <a href="/posts/<%= post.id %>">See in Details</a> | 
            <a href="/posts/<%= post.id %>/edit">Edit</a>
            
            <br><br>
            <form method="POST" action="/posts/<%= post.id %>?_method=DELETE">
                <button type="submit" style="background-color: red; color: white; border: none; padding: 5px 10px; border-radius: 5px; cursor: pointer;">Delete Post</button>
            </form>
        </div>
       <% } %>
   </div>

   <br/>
   <a href="/posts/news">Create New Post</a>
</body>
</html>