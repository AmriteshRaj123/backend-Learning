<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quora Posts</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>

    <h3>Quora Posts</h3>

    <% for (let post of posts) { %>
        <div class="post">
            <h3 class="username">@<%= post.username %></h3>
            <p class="content"><%= post.content %></p>

            <br>
             <a href="http://localhost:3000/posts/<%= post.id %>">
              See in details
             </a>
             <br>
             <br>
             <a href="http://localhost:3000/posts/<%= post.id%> /edit">
              Edit Post
             </a>



                <br>
                <br>
             <a class="details-btn" href="/posts/<%= post.id %>">
              Show More
              </a>


        </div>
    <% } %>

    <a href="http://localhost:3000/posts/news">Create New </a>

</body>
</html>